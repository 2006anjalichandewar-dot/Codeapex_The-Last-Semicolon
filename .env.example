# Copy to .env and adjust
ZT_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/zerotrust_docs
ZT_SECRET_KEY=change-me
ZT_ACCESS_TOKEN_EXPIRE_MINUTES=60
ZT_REDIS_URL=redis://localhost:6379/0
ZT_FABRIC_ENABLED=false
ZT_FABRIC_GATEWAY_URL=http://localhost:8801
ZT_FABRIC_TIMEOUT_SECONDS=5
